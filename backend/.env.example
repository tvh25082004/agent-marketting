NINE_ROUTER_BASE_URL=http://localhost:20128/v1
NINE_ROUTER_API_KEY=sk-259b9f08e24eebc4-5afkfh-ccf90543

# Fallback: OpenAI (nếu không dùng 9Router)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Fallback: Anthropic (nếu không dùng 9Router)
ANTHROPIC_API_KEY=
